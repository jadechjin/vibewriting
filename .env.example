# paper-search MCP server
SERPAPI_API_KEY=
LLM_PROVIDER=
LLM_MODEL=
LLM_BASE_URL=
OPENAI_API_KEY=

# Dify knowledge base (VW_ prefix required for vibewriting namespace)
VW_DIFY_API_BASE_URL=https://api.dify.ai/v1
VW_DIFY_API_KEY=
VW_DIFY_DATASET_ID=

# NOTE: Pipeline configuration (random_seed, float_precision, dedup_threshold,
# compile_max_retries, compile_timeout_sec) has been moved to paper_config.yaml.
# Environment variables below still work as overrides when set:
# VW_RANDOM_SEED=42
# VW_FLOAT_PRECISION=6
# VW_DEDUP_THRESHOLD=0.9
# VW_COMPILE_MAX_RETRIES=5
# VW_COMPILE_TIMEOUT_SEC=120

# Compilation & quality (Phase 6) - env-only fields
VW_PATCH_WINDOW_LINES=10
VW_ENABLE_LAYOUT_CHECK=false
VW_ENABLE_AI_DISCLOSURE=false
VW_CROSSREF_API_EMAIL=
